# Conexão com o PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financa_simples?schema=public"

# Segredos do JWT — gere valores fortes, ex.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-de-no-minimo-32-caracteres"
JWT_REFRESH_SECRET="troque-por-outro-segredo-de-no-minimo-32-caracteres"

# Porta da API
PORT=3333

# Origem permitida no CORS (frontend Vite em dev)
CORS_ORIGIN="http://localhost:5173"
